# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=smartcart
POSTGRES_PASSWORD=changeme
POSTGRES_DB=smartcart_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://smartcart:changeme@postgres:5432/smartcart_db

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Backend ──────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ENVIRONMENT=development
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── AI agent ─────────────────────────────────────────────────────────────────
# Provider: "auto" = Gemini pokud je klíč, jinak Claude. Nebo "gemini"/"anthropic".
AGENT_PROVIDER=auto
# Gemini — zdarma: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
# Claude (placené) — https://platform.claude.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-opus-4-8

# ── Rohlík (volitelné — účet se připojuje per-user v aplikaci) ────────────────
ROHLIK_BASE_URL=https://www.rohlik.cz

# ── Revolut (sandbox) ────────────────────────────────────────────────────────
REVOLUT_CLIENT_ID=your-revolut-client-id
REVOLUT_CLIENT_SECRET=your-revolut-client-secret
REVOLUT_SANDBOX=true

# ── Firebase (push notifications) ────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# ── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
